# Fill these from `terraform output` and copy to aws.env
#
# Cognito (from terraform output)
COGNITO_DOMAIN=https://YOUR_PREFIX.auth.eu-west-1.amazoncognito.com
COGNITO_CLIENT_ID=your-cognito-client-id
VPN_AUTH_COGNITO_TOKEN_ENDPOINT=https://YOUR_PREFIX.auth.eu-west-1.amazoncognito.com/oauth2/token
VPN_AUTH_COGNITO_CLIENT_ID=your-cognito-client-id
VPN_AUTH_COGNITO_REDIRECT_URI=http://localhost:8080/callback
VPN_AUTH_COGNITO_ISSUER_URL=https://cognito-idp.eu-west-1.amazonaws.com/YOUR_USER_POOL_ID
