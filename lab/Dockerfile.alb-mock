FROM golang:1.26.4-alpine AS builder

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o alb-mock ./cmd/alb-mock

FROM alpine:3.24

RUN apk --no-cache add ca-certificates wget

WORKDIR /app

COPY --from=builder /build/alb-mock .

RUN adduser -S -D -H -u 10001 -G daemon appuser
USER appuser

EXPOSE 8080

CMD ["/app/alb-mock"]
